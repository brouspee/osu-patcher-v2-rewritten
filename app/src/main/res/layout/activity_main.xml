<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D14">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#13131F"
        android:padding="20dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="osu! DLL Patcher"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FF66AA"
            android:letterSpacing="0.05"
            android:fontFamily="monospace"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="bind mount · root required"
            android:textSize="11sp"
            android:textColor="#555577"
            android:layout_marginTop="2dp"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <!-- Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1A1A28"
        android:padding="16dp"
        android:layout_marginTop="1dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STATUS  "
            android:textSize="11sp"
            android:textColor="#444466"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Checking..."
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <!-- Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginTop="4dp">

        <Button
            android:id="@+id/btn_pick"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="ВЫБРАТЬ ФАЙЛ (.dll / .cs / .blob)"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:fontFamily="monospace"
            android:backgroundTint="#1E1E30"
            android:layout_marginBottom="10dp"
            android:letterSpacing="0.05"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ИМЯ СБОРКИ В BLOB (без .dll, автозаполняется)"
            android:textSize="9sp"
            android:textColor="#445566"
            android:fontFamily="monospace"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/et_target_name"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="например: osu.Game.Rulesets.Osu"
            android:textSize="12sp"
            android:textColor="#AABBCC"
            android:textColorHint="#334455"
            android:fontFamily="monospace"
            android:background="#111120"
            android:paddingHorizontal="12dp"
            android:inputType="text"
            android:maxLines="1"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="→ ищет libaot-ИМЯ.dll.so в lib/arm64/"
            android:textSize="9sp"
            android:textColor="#2a3a4a"
            android:fontFamily="monospace"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btn_apply"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="APPLY PATCH"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:backgroundTint="#CC3377"
            android:layout_marginBottom="10dp"
            android:letterSpacing="0.1"/>

        <Button
            android:id="@+id/btn_unmount"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="REMOVE PATCH"
            android:textSize="11sp"
            android:textColor="#AA8899"
            android:fontFamily="monospace"
            android:backgroundTint="#111120"
            android:letterSpacing="0.06"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E1E30"
        android:layout_marginHorizontal="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LOG"
        android:textSize="10sp"
        android:textColor="#334455"
        android:fontFamily="monospace"
        android:letterSpacing="0.2"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"/>

    <ScrollView
        android:id="@+id/scroll_log"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:background="#0A0A12"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tv_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#7788AA"
            android:fontFamily="monospace"
            android:lineSpacingExtra="3dp"
            android:text=""/>
    </ScrollView>

</LinearLayout>
